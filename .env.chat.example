# 법령 리서치 챗 서비스용 환경변수 템플릿
# 사용법: 이 파일을 `.env`로 복사하고 실제 값으로 채우세요.
#   cp .env.chat.example .env
#
# `.env`는 .gitignore에 등록되어 있어 커밋되지 않습니다.

# ─── 필수 ───────────────────────────────────────────────

# Anthropic Claude API 키
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# 법제처 오픈API 인증키 (OC 코드)
# 발급: https://open.law.go.kr/LSO/openApi/guideResult.do
LAW_OC=your-oc-code

# ─── 선택 ───────────────────────────────────────────────

# 챗 서버 포트 (기본 8080)
# CHAT_PORT=8080

# 사용할 Claude 모델 (정확성 우선이면 claude-opus-4-7)
# CHAT_MODEL=claude-sonnet-4-6

# 요청 본문 크기 제한
# CHAT_BODY_LIMIT=200kb
